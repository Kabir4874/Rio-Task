{
  "name": "rio-task-root",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "prepare": "node -e \"if (process.env.NODE_ENV !== 'production' && !process.env.CI) { try { require('child_process').execSync('husky', { stdio: 'inherit' }) } catch (e) {} }\"",
    "dev": "concurrently --kill-others \"npm run start:dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "build": "npm run build --prefix backend && npm run build --prefix frontend",
    "lint": "npm run lint --prefix backend && npm run lint --prefix frontend",
    "format": "prettier --write \"backend/src/**/*.ts\" \"frontend/src/**/*.{ts,tsx,css}\" \"*.{json,js,mjs,md}\"",
    "format:check": "prettier --check \"backend/src/**/*.ts\" \"frontend/src/**/*.{ts,tsx,css}\" \"*.{json,js,mjs,md}\"",
    "test": "npm test --prefix backend",
    "verify": "npm run lint && npm run format:check && npm run build && npm run test"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.4.2"
  },
  "lint-staged": {
    "backend/src/**/*.ts": [
      "eslint --config backend/eslint.config.mjs --fix",
      "prettier --write"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint --config frontend/eslint.config.js --fix",
      "prettier --write"
    ],
    "*.{json,js,mjs,md,css}": [
      "prettier --write"
    ]
  }
}
